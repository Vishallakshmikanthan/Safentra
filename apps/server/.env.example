PORT=3001
NODE_ENV=production
# Comma-separated browser origins permitted to call the API.
CORS_ORIGINS=https://app.example.com

# ── AI Agents (ORACLE, FORGE, BLAZE) ──────────────────────────────────────────
# Get a free key (no credit card) at https://build.nvidia.com — open any model
# card, click "Get API Key". Without this set, all three agents fall back to
# deterministic template/keyword logic automatically — the app still runs.
NEMOTRON_API_KEY=nvapi-your-key-here
# Optional overrides:
# NEMOTRON_BASE_URL=https://integrate.api.nvidia.com/v1
# NEMOTRON_MODEL=nvidia/nemotron-3-super-120b-a12b

# Alternative: if you get an Anthropic key later, ANTHROPIC_API_KEY can be
# wired in the same way via a parallel client (not required, Nemotron alone
# is sufficient to run ORACLE/FORGE/BLAZE).
# ANTHROPIC_API_KEY=
